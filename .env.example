# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional override for HTTP API (Railway Variables)
# GEMINI_MODEL=gemini-2.0-flash

# Optional: if set, POST /v1/... requires header: Authorization: Bearer <same value>
# MAMODOC_API_KEY=

# Credit note auto-number (persisted in data/cn_counter.json, or CN_COUNTER_PATH)
# CN_NUMBER_PREFIX=UNI
# CN_COUNTER_LAST=261093
# CN_INITIAL_NEXT=261093
# CN_COUNTER_PATH=/data/cn_counter.json
